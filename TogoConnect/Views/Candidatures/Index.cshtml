@* ── Views/Candidatures/Index.cshtml (étudiant) ── *@
@model List<TogoConnect.Models.Candidature>
@{ ViewBag.Title = "Mes candidatures"; Layout = "~/Views/Shared/_Layout.cshtml"; }

<h3 class="mb-4"><i class="bi bi-send"></i> Mes candidatures</h3>

@if (!Model.Any()) {
  <div class="alert alert-info">
    <i class="bi bi-info-circle"></i> Vous n'avez encore déposé aucune candidature.
    <a href="@Url.Action("Index","Offres")" class="alert-link">Parcourir les offres</a>
  </div>
} else {
  <div class="table-responsive">
    <table class="table table-hover align-middle">
      <thead class="table-dark">
        <tr><th>Offre</th><th>Entreprise</th><th>Type</th><th>Date dépôt</th><th>Statut</th><th></th></tr>
      </thead>
      <tbody>
        @foreach (var c in Model) {
          <tr>
            <td class="fw-semibold">@c.Offre?.Titre</td>
            <td>@c.Offre?.Entreprise?.RaisonSociale</td>
            <td><span class="badge bg-secondary">@c.Offre?.TypeOffre</span></td>
            <td>@c.DateDepot.ToString("dd/MM/yyyy")</td>
            <td>
              @{
                var badgeClass = c.Statut == "acceptee" ? "bg-success"
                               : c.Statut == "refusee"  ? "bg-danger"
                               : "bg-warning text-dark";
              }
              <span class="badge @badgeClass">@c.Statut.Replace("_", " ")</span>
            </td>
            <td>
              @if (c.Statut == "en_attente") {
                <button class="btn btn-sm btn-outline-danger btn-retirer" data-id="@c.Id">
                  <i class="bi bi-x-circle"></i> Retirer
                </button>
              }
            </td>
          </tr>
        }
      </tbody>
    </table>
  </div>
}

@section Scripts {
  <script>
    document.querySelectorAll('.btn-retirer').forEach(btn => {
      btn.addEventListener('click', function() {
        if (!confirm('Retirer cette candidature ?')) return;
        fetch('@Url.Action("Retirer","Candidatures")', {
          method: 'POST',
          headers: {'Content-Type':'application/x-www-form-urlencoded'},
          body: 'id=' + this.dataset.id + '&__RequestVerificationToken=' +
                document.querySelector('[name=__RequestVerificationToken]')?.value
        }).then(r => r.json()).then(d => { if(d.succes) location.reload(); });
      });
    });
  </script>
  @Html.AntiForgeryToken()
}
