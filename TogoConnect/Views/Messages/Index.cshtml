@* ── Views/Messages/Index.cshtml ── *@
@model List<TogoConnect.Models.Utilisateur>
@{ ViewBag.Title = "Messagerie"; Layout = "~/Views/Shared/_Layout.cshtml"; }

<h3 class="mb-4"><i class="bi bi-chat-dots"></i> Messagerie</h3>

@if (!Model.Any()) {
  <div class="alert alert-info">
    <i class="bi bi-info-circle"></i> Aucune conversation pour l'instant.
  </div>
} else {
  <div class="list-group shadow-sm">
    @foreach (var u in Model) {
      <a href="@Url.Action("Conversation", new { id = u.Id })"
         class="list-group-item list-group-item-action d-flex align-items-center gap-3 py-3">
        <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center"
             style="width:42px;height:42px;font-weight:700;font-size:1.1rem">
          @u.Nom.Substring(0,1).ToUpper()
        </div>
        <div>
          <div class="fw-semibold">@u.NomComplet</div>
          <small class="text-muted">@(u.Role == "entreprise" ? "Entreprise" : "Étudiant")</small>
        </div>
        <i class="bi bi-chevron-right ms-auto text-muted"></i>
      </a>
    }
  </div>
}


@* ── Views/Messages/Conversation.cshtml ── *@
@* @model List<TogoConnect.Models.Message>
@{ ViewBag.Title = "Conversation"; Layout = "~/Views/Shared/_Layout.cshtml"; }

<div class="row justify-content-center">
  <div class="col-md-8">
    <div class="d-flex align-items-center mb-3 gap-2">
      <a href="@Url.Action("Index")" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left"></i></a>
      <h5 class="mb-0">@ViewBag.Interlocuteur?.NomComplet</h5>
    </div>

    <div class="card shadow-sm" style="height:450px;overflow-y:auto;display:flex;flex-direction:column-reverse" id="msgBox">
      <div class="p-3">
        @foreach (var msg in Model) {
          bool isMoi = msg.IdExpediteur == (int)Session["UserId"];
          <div class="d-flex @(isMoi ? "justify-content-end" : "justify-content-start") mb-2">
            <div class="rounded p-2 px-3 @(isMoi ? "bg-primary text-white" : "bg-light border")"
                 style="max-width:70%">
              <div>@msg.Contenu</div>
              <small class="@(isMoi?"text-white-50":"text-muted") d-block text-end" style="font-size:.7rem">
                @msg.DateEnvoi.ToString("HH:mm")
              </small>
            </div>
          </div>
        }
      </div>
    </div>

    @using (Html.BeginForm("Envoyer", "Messages", FormMethod.Post, new { @class = "mt-3 d-flex gap-2" })) {
      @Html.AntiForgeryToken()
      <input type="hidden" name="idDestinataire" value="@ViewBag.Interlocuteur?.Id" />
      <input type="text" name="contenu" class="form-control" placeholder="Écrire un message..." required autocomplete="off" />
      <button type="submit" class="btn btn-primary"><i class="bi bi-send"></i></button>
    }
  </div>
</div> *@
