@* ── Views/Offres/Index.cshtml ── *@
@model List<TogoConnect.Models.Offre>
@{ ViewBag.Title = "Offres disponibles"; Layout = "~/Views/Shared/_Layout.cshtml"; }

<div class="d-flex justify-content-between align-items-center mb-4">
  <h2><i class="bi bi-briefcase"></i> Offres disponibles</h2>
  @if (Session["UserRole"] != null && Session["UserRole"].ToString() == "entreprise") {
    <a href="@Url.Action("Creer")" class="btn btn-primary">
      <i class="bi bi-plus-circle"></i> Publier une offre
    </a>
  }
</div>

@using (Html.BeginForm("Index", "Offres", FormMethod.Get, new { @class = "row g-2 mb-4" })) {
  <div class="col-md-3">
    <select name="type" class="form-select">
      <option value="">Tous les types</option>
      <option value="emploi">Emploi</option>
      <option value="stage">Stage</option>
      <option value="formation">Formation</option>
      <option value="evenement">Événement</option>
    </select>
  </div>
  <div class="col-md-4">
    <input type="text" name="localisation" class="form-control" placeholder="Ville..." />
  </div>
  <div class="col-md-4">
    <input type="text" name="recherche" class="form-control" placeholder="Mot-clé, titre..." />
  </div>
  <div class="col-md-1">
    <button type="submit" class="btn btn-primary w-100"><i class="bi bi-search"></i></button>
  </div>
}

@if (!Model.Any()) {
  <div class="alert alert-info text-center">
    <i class="bi bi-info-circle"></i> Aucune offre ne correspond à vos critères.
  </div>
} else {
  <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
    @foreach (var offre in Model) {
      <div class="col">
        <div class="card card-offre h-100 shadow-sm">
          <div class="card-body">
            <span class="badge badge-type-@offre.TypeOffre mb-2 text-white" style="background:@(offre.TypeOffre=="emploi"?"#1565C0":offre.TypeOffre=="stage"?"#2E7D32":offre.TypeOffre=="formation"?"#E65100":"#6A1B9A")">
              @offre.TypeOffre.ToUpper()
            </span>
            <h6 class="card-title fw-bold">@offre.Titre</h6>
            <p class="text-muted small mb-1"><i class="bi bi-building"></i> @offre.Entreprise?.RaisonSociale</p>
            <p class="text-muted small mb-2"><i class="bi bi-geo-alt"></i> @offre.Localisation</p>
            <p class="card-text small text-truncate" style="max-height:60px;overflow:hidden">
              @(offre.Description.Length > 100 ? offre.Description.Substring(0, 100) + "..." : offre.Description)
            </p>
          </div>
          <div class="card-footer d-flex justify-content-between align-items-center">
            <small class="text-muted"><i class="bi bi-calendar"></i> @offre.DateLimite.ToString("dd/MM/yyyy")</small>
            <a href="@Url.Action("Details", new { id = offre.Id })" class="btn btn-sm btn-outline-primary">Voir l'offre</a>
          </div>
        </div>
      </div>
    }
  </div>
}
