@model List<TogoConnect.Models.Message>
@{ ViewBag.Title = "Conversation"; Layout = "~/Views/Shared/_Layout.cshtml"; }

<div class="row justify-content-center">
  <div class="col-md-8">
    <div class="d-flex align-items-center mb-3 gap-2">
      <a href="@Url.Action("Index")" class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Retour
      </a>
      <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center"
           style="width:38px;height:38px;font-weight:700">
        @(ViewBag.Interlocuteur?.Nom?.Substring(0,1).ToUpper())
      </div>
      <h5 class="mb-0">@ViewBag.Interlocuteur?.NomComplet</h5>
    </div>

    <div class="card shadow-sm mb-3">
      <div class="card-body p-3" id="msgBox" style="height:420px;overflow-y:auto;">
        @if (!Model.Any()) {
          <p class="text-center text-muted mt-5">Démarrez la conversation !</p>
        }
        @foreach (var msg in Model) {
          bool isMoi = msg.IdExpediteur == (int)Session["UserId"];
          <div class="d-flex @(isMoi ? "justify-content-end" : "justify-content-start") mb-2">
            <div class="rounded p-2 px-3 @(isMoi ? "bg-primary text-white" : "bg-light border")"
                 style="max-width:72%">
              <div style="white-space:pre-wrap">@msg.Contenu</div>
              <small class="@(isMoi ? "text-white-50":"text-muted") d-block text-end" style="font-size:.7rem">
                @msg.DateEnvoi.ToString("dd/MM HH:mm")
              </small>
            </div>
          </div>
        }
      </div>
    </div>

    @using (Html.BeginForm("Envoyer", "Messages", FormMethod.Post, new { @class = "d-flex gap-2" })) {
      @Html.AntiForgeryToken()
      <input type="hidden" name="idDestinataire" value="@ViewBag.Interlocuteur?.Id" />
      <input type="text" name="contenu" id="inputMsg" class="form-control"
             placeholder="Écrire un message..." required autocomplete="off" />
      <button type="submit" class="btn btn-primary px-3">
        <i class="bi bi-send-fill"></i>
      </button>
    }
  </div>
</div>

@section Scripts {
  <script>
    // Scroll vers le bas automatiquement
    var box = document.getElementById('msgBox');
    if (box) box.scrollTop = box.scrollHeight;
    // Focus sur l'input
    document.getElementById('inputMsg')?.focus();
  </script>
}
