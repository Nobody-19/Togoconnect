@* ============================================================
   TogoConnect – Views/Shared/_Layout.cshtml
   ============================================================ *@
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title – TogoConnect</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"/>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" rel="stylesheet"/>
    <style>
        :root { --tc-primary: #1565C0; --tc-secondary: #0D47A1; }
        .navbar { background: var(--tc-primary) !important; }
        .navbar-brand { font-weight: 700; font-size: 1.4rem; }
        .badge-notif { position:relative; top:-8px; left:-6px; font-size:.65rem; }
        .card-offre { transition: transform .2s, box-shadow .2s; }
        .card-offre:hover { transform: translateY(-3px); box-shadow: 0 6px 20px rgba(0,0,0,.12); }
        .badge-type-emploi    { background:#1565C0; }
        .badge-type-stage     { background:#2E7D32; }
        .badge-type-formation { background:#E65100; }
        .badge-type-evenement { background:#6A1B9A; }
        footer { background:#1a1a2e; color:#ccc; }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark">
        <div class="container">
            <a class="navbar-brand text-white" href="@Url.Action("Index","Home")">
                <i class="bi bi-people-fill"></i> TogoConnect
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navMenu">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item"><a class="nav-link text-white" href="@Url.Action("Index","Offres")"><i class="bi bi-briefcase"></i> Offres</a></li>
                </ul>
                <ul class="navbar-nav">
                    @if (Request.IsAuthenticated)
                    {
                        <li class="nav-item">
                            <a class="nav-link text-white" href="@Url.Action("Index","Messages")">
                                <i class="bi bi-chat-dots"></i>
                                @if (ViewBag.MessagesNonLus != null && (int)ViewBag.MessagesNonLus > 0)
                                {
                                    <span class="badge bg-danger badge-notif">@ViewBag.MessagesNonLus</span>
                                }
                            </a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-white" href="#" data-bs-toggle="dropdown">
                                <i class="bi bi-person-circle"></i> @Session["UserNom"]
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" href="@Url.Action("Index","Dashboard")"><i class="bi bi-speedometer2"></i> Tableau de bord</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item text-danger" href="@Url.Action("Deconnexion","Account")"><i class="bi bi-box-arrow-right"></i> Déconnexion</a></li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item"><a class="nav-link text-white" href="@Url.Action("Connexion","Account")">Connexion</a></li>
                        <li class="nav-item"><a class="btn btn-light btn-sm ms-2 mt-1" href="@Url.Action("Inscription","Account")">S'inscrire</a></li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <main class="py-4">
        <div class="container">
            @if (TempData["Succes"] != null)
            { <div class="alert alert-success alert-dismissible fade show"><i class="bi bi-check-circle"></i> @TempData["Succes"] <button type="button" class="btn-close" data-bs-dismiss="alert"></button></div> }
            @if (TempData["Erreur"] != null)
            { <div class="alert alert-danger alert-dismissible fade show"><i class="bi bi-exclamation-triangle"></i> @TempData["Erreur"] <button type="button" class="btn-close" data-bs-dismiss="alert"></button></div> }
            @RenderBody()
        </div>
    </main>

    <footer class="py-4 mt-5">
        <div class="container text-center">
            <p class="mb-0">&copy; @DateTime.Now.Year TogoConnect – Plateforme d'Opportunités pour les Jeunes Togolais</p>
            <small>Projet ECT 330 – Génie Logiciel – Université de Lomé</small>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
