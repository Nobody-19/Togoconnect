@* ── Views/Offres/Creer.cshtml ── *@
@model TogoConnect.Models.Offre
@{ ViewBag.Title = "Publier une offre"; Layout = "~/Views/Shared/_Layout.cshtml"; }

<div class="row justify-content-center">
  <div class="col-md-8">
    <h3 class="mb-4"><i class="bi bi-plus-circle"></i> Publier une nouvelle offre</h3>
    @if (ViewBag.Erreur != null) { <div class="alert alert-danger">@ViewBag.Erreur</div> }

    @using (Html.BeginForm("Creer", "Offres", FormMethod.Post)) {
      @Html.AntiForgeryToken()
      <div class="card shadow-sm p-4">
        <div class="mb-3">
          <label class="form-label fw-semibold">Titre de l'offre *</label>
          @Html.TextBoxFor(m => m.Titre, new { @class = "form-control", placeholder = "Ex : Développeur Web Full Stack", required = "required" })
        </div>
        <div class="row">
          <div class="col-md-6 mb-3">
            <label class="form-label fw-semibold">Type d'offre *</label>
            @Html.DropDownListFor(m => m.TypeOffre, new SelectList(new[] {
              new { V="", T="Choisir..." },
              new { V="emploi", T="Emploi" },
              new { V="stage", T="Stage" },
              new { V="formation", T="Formation" },
              new { V="evenement", T="Événement" }
            }, "V", "T"), new { @class = "form-select", required = "required" })
          </div>
          <div class="col-md-6 mb-3">
            <label class="form-label fw-semibold">Localisation</label>
            @Html.TextBoxFor(m => m.Localisation, new { @class = "form-control", placeholder = "Ex : Lomé, Togo" })
          </div>
        </div>
        <div class="mb-3">
          <label class="form-label fw-semibold">Description *</label>
          @Html.TextAreaFor(m => m.Description, new { @class = "form-control", rows = "6",
            placeholder = "Décrivez le poste, les missions, le profil recherché...", required = "required" })
        </div>
        <div class="mb-3">
          <label class="form-label fw-semibold">Compétences requises</label>
          @Html.TextBoxFor(m => m.Competences, new { @class = "form-control", placeholder = "Ex : C#, SQL Server, ASP.NET (séparées par des virgules)" })
        </div>
        <div class="mb-3">
          <label class="form-label fw-semibold">Date limite de candidature *</label>
          @Html.TextBoxFor(m => m.DateLimite, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date", required = "required" })
        </div>
        <div class="d-flex gap-2">
          <button type="submit" class="btn btn-success"><i class="bi bi-send"></i> Publier l'offre</button>
          <a href="@Url.Action("MesOffres")" class="btn btn-outline-secondary">Annuler</a>
        </div>
      </div>
    }
  </div>
</div>
